pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                dir('admin-module') {
                    bat 'mvnw.cmd clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('admin-module') {
                    bat 'mvnw.cmd test'
                }
            }
        }
    }
}